DirectoryIndex index.php

# Deny access to src directory and sensitive files
RewriteEngine On

# Block direct access to src/ and sensitive files
RewriteRule ^src/ - [F,L]
RewriteRule \.(sqlite|sql|md)$ - [F,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
